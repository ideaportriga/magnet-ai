#!/usr/bin/env sh

# Get the list of staged files. Newline-separated for grep; the `git add` step
# below pipes through NUL so paths containing spaces (e.g. `Foo copy.vue`)
# stay as one argument instead of being split by xargs.
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

API_FILES=$(printf '%s\n' "$STAGED_FILES" | grep '^api/.*\.py$' || true)
WEB_FILES=$(printf '%s\n' "$STAGED_FILES" | grep '^web/.*\.\(js\|ts\|vue\)$' || true)

# Run ruff for API changes.
if [ -n "$API_FILES" ]; then
  echo "🔍 Running format check for API..."
  npm run format:api || exit 1
  echo "🔍 Running lint for API..."
  npm run lint:api || exit 1
  # Re-stage fixed files. NUL-delimit so paths with spaces stay one argument.
  printf '%s\n' "$API_FILES" | tr '\n' '\0' | xargs -0 git add --
fi

# Run eslint for Web changes through Nx affected projects derived from staged files.
if [ -n "$WEB_FILES" ]; then
  echo "🔍 Running lint for Web..."
  WEB_LINT_FILES=$(printf '%s\n' "$WEB_FILES" | sed 's#^web/##' | paste -sd, -)
  (cd web && yarn nx affected --target=lint --files="$WEB_LINT_FILES" --fix) || exit 1
  printf '%s\n' "$WEB_FILES" | tr '\n' '\0' | xargs -0 git add --
fi

echo "✅ Pre-commit checks passed!"

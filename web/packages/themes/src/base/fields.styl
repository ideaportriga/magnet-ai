// =============================================================================
// FIELD / INPUT STYLES
// =============================================================================
// All sizing via component tokens (--field-height, --field-radius, etc.)
// defined in tokens/_components.styl
// =============================================================================

// =============================================================================
// GENERIC CONTROL
// =============================================================================

.km-control, .km-picker
  min-height: var(--field-height)
  transition: background, border-color 300ms


// =============================================================================
// PICKER
// =============================================================================

.km-picker
  cursor: pointer
  &.km-field-error
    border: 2px solid var(--q-error-text)


// =============================================================================
// SELECT / DROPDOWN
// =============================================================================

.km-select
  border-radius: var(--field-radius)
  overflow: hidden !important

  &.km-open-popup
    background: var(--q-control-active-bg) !important
    border-color: var(--q-control-active-border) !important

  .q-field__native
    height: var(--field-height) !important
    max-height: var(--field-max-height) !important
    min-height: var(--field-min-height) !important
    gap: 4px !important

    .q-chip
      margin: 0px !important
      max-width: 300px
      .q-icon
        margin-top: auto
        margin-bottom: auto
        margin-right: -0.2em
        line-height: 18px

  .q-field__control
    height: var(--field-height) !important
    max-height: var(--field-max-height) !important
    min-height: var(--field-min-height) !important
    padding: 0px 8px !important

    .q-field__native
      min-height: var(--field-min-height) !important
      max-height: var(--field-max-height) !important
      font-family: var(--font-default)
      font-size: 14px
      font-weight: 500
      color: var(--q-secondary-text)

    .q-field__marginal
      min-height: var(--field-min-height) !important
      max-height: var(--field-max-height) !important
      color: var(--q-icon)

    .q-field__append
      height: var(--field-height) !important
      max-height: var(--field-max-height) !important
      color: var(--q-seemless)


// =============================================================================
// INPUT (text, number, etc.)
// =============================================================================

// All inputs including readonly
.km-input
  height: var(--field-height) !important

  .q-field--dense
    height: var(--field-height) !important

  .q-field__prefix
    padding: 0px !important

  .q-field__control
    height: var(--field-height) !important
    padding: 0px 6px 0px 8px !important
    border-radius: var(--field--border-radius) !important
    transition: background, border 600ms

    & .q-field__prepend
      height: auto !important

    & .q-field__append
      height: auto !important

    .q-field__native
      padding-left: 6px
      padding-right: 6px
      font-family: var(--font-default)
      line-height: 17px
      font-size: 14px
      font-weight: 400

    &:hover::before
      border-color: var(--q-control-border) !important
      transition: background, border 600ms

  &.q-textarea
    .q-field__control
      height: 100% !important
      min-height: var(--field-min-height) !important
      max-height: var(--field-max-height) !important
      &-container
        // Keep horizontal padding symmetric with non-textarea inputs so
        // content never renders flush-left. Using longhand (not the
        // `padding: 0` shorthand) so only vertical is zeroed — the 6px
        // on the `.q-field__native` below then produces the same total
        // horizontal inset as the plain-input branch.
        padding-top: 0
        padding-bottom: 0
      .q-field__native
        min-height: var(--field-initial-height) !important
        max-height: var(--field-max-height) !important
        padding-top: calc((var(--field-initial-height) - 17px) / 2)
        padding-bottom: calc((var(--field-initial-height) - 17px) / 2)
        // Explicit left/right padding with !important so a future
        // Quasar update (or a higher-specificity theme rule) cannot
        // silently zero the textarea's horizontal inset the way the
        // old `&-container { padding: 0 }` shorthand used to.
        padding-left: 6px !important
        padding-right: 6px !important


// Editable inputs only
.km-input:not(.q-field--readonly)

  .q-field__control

    & .q-field__prepend
      padding: 0px
      height: auto !important
      max-height: auto !important
      color: rgba(92, 92, 92, 0.5)

    & .q-field__append
      padding: 0px
      height: auto !important
      max-height: auto !important
      color: rgba(92, 92, 92, 0.5)

    &::before
      border-color: var(--q-control-border) !important
      transition: all 600ms
      background: var(--q-control-bg)

    &:hover::before
      border-color: var(--q-control-hover-border) !important
      background: var(--q-control-hover-bg)
      transition: background, border 600ms

  &.q-field--outlined.q-field--highlighted .q-field__control::before
    border-color: var(--q-control-active-border)
    transition: background, border 600ms
    background: var(--q-control-active-bg) !important

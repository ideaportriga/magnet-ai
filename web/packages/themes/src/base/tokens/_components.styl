// =============================================================================
// COMPONENT TOKENS
// =============================================================================
// CSS custom properties for individual components.
// Values reference radius/spacing tokens where possible.
// =============================================================================

:root
  // Buttons
  --btn-height-xs:    22px
  --btn-height-sm:    36px
  --btn-height-md:    34px
  --btn-height-lg:    40px
  --btn-radius:       6px   // $radius-md
  // Legacy aliases (keep until all usages migrated)
  --button-sm:        var(--btn-height-sm)
  --button-xs:        var(--btn-height-xs)

  // Inputs / Fields
  --field-height:     34px
  --field-radius:     6px   // $radius-md
  --field-min-height: 34px
  --field-max-height: 200px
  --field-initial-height: 34px
  --field--border-radius: var(--field-radius)

  // Prompt input
  --prompt-input-height:     36px
  --prompt-input-icon-size:  16px

  // Cards
  --card-radius:      12px  // $radius-xl
  --card-padding:     16px

  // Dialogs
  --dialog-radius:    8px   // $radius-lg
  --dialog-padding:   24px
  --dialog-width-sm:  400px
  --dialog-width-md:  500px
  --dialog-width-lg:  676px

  // Chips
  --chip-height:      20px
  --chip-radius:      4px   // $radius-sm

  // Checkboxes
  --checkbox-size:    40px

  // Tables
  --table-row-height: 48px

  // Loaders (three-body, etc.)
  --uib-size:         40px
  --uib-speed:        0.9s
  --uib-color:        var(--q-primary)

// =============================================================================
// ELEVATION / SHADOW TOKENS
// =============================================================================

$shadow-none    = none
$shadow-sm      = 0px 1px 4px rgba(0, 0, 0, 0.06)
$shadow-md      = 0px 2px 10px rgba(0, 0, 0, 0.08)
$shadow-lg      = 0px 4px 12px rgba(0, 0, 0, 0.10)
$shadow-xl      = 0px 8px 24px rgba(0, 0, 0, 0.12)
$shadow-primary = 0px 2px 8px rgba(104, 64, 194, 0.25)

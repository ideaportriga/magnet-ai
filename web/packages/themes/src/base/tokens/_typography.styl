// =============================================================================
// TYPOGRAPHY TOKENS
// =============================================================================
// CSS custom properties for font sizes, weights, and line heights.
// Referenced by typography.styl classes.
// Themes can override these values to adjust the entire type scale.
// =============================================================================

:root
  // Font families
  --km-font-default: "Geist", "Inter", sans-serif
  --km-font-mono: "Geist Mono", 'JetBrains Mono', 'Fira Code', Consolas, monospace

  // Font sizes — 9-step scale
  --km-font-size-xs:      10px   // small-chip, description-2
  --km-font-size-sm:      11px   // tiny
  --km-font-size-caption:  12px  // caption, label, chip, input-label, field
  --km-font-size-label:   13px   // body-sm, h5, btn, link, button-sm-text
  --km-font-size-body:    14px   // body, h4, link-title
  --km-font-size-body-lg: 16px   // body-lg, h3
  --km-font-size-h2:      18px   // h2, logo, chart-value
  --km-font-size-h1:      20px   // h1
  --km-font-size-display: 24px   // display

  // Font weights
  --km-font-weight-regular:  400
  --km-font-weight-medium:   500
  --km-font-weight-semibold: 600
  --km-font-weight-bold:     700

  // Line heights
  --km-line-height-none:    1
  --km-line-height-tight:   1.2
  --km-line-height-snug:    1.3
  --km-line-height-normal:  1.4
  --km-line-height-relaxed: 1.5

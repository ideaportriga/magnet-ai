// =============================================================================
// FACTORY — Generic styles reusable across applications
// =============================================================================
// Imports design tokens and generates utility classes.
// =============================================================================

@import './functions.styl'
@import './tokens/_colors.styl'
@import './tokens/_radii.styl'
@import './tokens/_spacing.styl'
@import './tokens/_elevation.styl'
@import './tokens/_components.styl'
@import './tokens/_typography.styl'


// =============================================================================
// COLORS — generate CSS variables and bg/text utility classes
// =============================================================================

generateColorClasses($colors, ':root')

// Hover background classes
$hoverBg = accent-bg

for $colorName, $colorValue in $hoverBg
  $cssVar = --q- + $colorName
  .hover-{$colorName}:hover
    background: var($cssVar) !important


// =============================================================================
// SPACING — generate q-{p|m}{direction}-{n} utility classes
// =============================================================================

$spacing-directions = {
  l: left,
  t: top,
  b: bottom,
  r: right,
}
$spacing-types = {
  p: padding,
  m: margin,
}

for $size in $spacing-sizes
  for $type-short, $type-attrib in $spacing-types
    for $dir-short, $dir-attrib in $spacing-directions
      .q-{$type-short}{$dir-short}-{$size}
        {$type-attrib}-{$dir-attrib}: $size px
    .q-{$type-short}a-{$size}
      {$type-attrib}: $size px
    .q-{$type-short}x-{$size}
      {$type-attrib}-left: $size px
      {$type-attrib}-right: $size px
    .q-{$type-short}y-{$size}
      {$type-attrib}-top: $size px
      {$type-attrib}-bottom: $size px
  .q-gap-{$size}
    gap: $size px


// =============================================================================
// BORDERS — generate b{direction}-{color} utility classes
// =============================================================================

$borderColors = {
  transparent:  transparent
  thin-dark:    rgba(0, 0, 0, 0.25)
  thin-light:   rgba(255, 255, 255, 0.1)
  primary:      $colors.primary
  border:       $colors.border
  border-2:     $colors.border-2
  error:        $colors.error
}

$borderWidth = 1px
$borderPositions = top, bottom, right, left, x, y, all

border-calc(pos, colorName, col)
  if (pos == all)
    .ba-{colorName}
      border: $borderWidth solid col
    .ba-{colorName}-important
      border: $borderWidth solid col !important
  else if (pos == x)
    .bx-{colorName}
      border-left: $borderWidth solid col
      border-right: $borderWidth solid col
  else if (pos == y)
    .by-{colorName}
      border-top: $borderWidth solid col
      border-bottom: $borderWidth solid col
  else
    .b{substr(pos, 0, 1)}-{colorName}
      border-{pos}: $borderWidth solid col

for $colorName, $color in $borderColors
  for $pos in $borderPositions
    border-calc($pos, $colorName, $color)


// =============================================================================
// ALIGNMENT utilities
// =============================================================================

.center-flex
  display: flex
  align-items: center
  justify-content: center

.center-flex-x
  display: flex
  justify-content: center

.center-flex-y
  display: flex
  align-items: center

.bottom-flex
  display: flex
  align-items: flex-end

.top-flex
  display: flex
  align-items: flex-start

.right-flex
  display: flex
  justify-content: flex-end


// =============================================================================
// MISC utilities
// =============================================================================

.q-ma-auto
  margin: auto

.q-pa-none
  padding: 0px !important

.rounded-borders-top
  border-top-right-radius: $radius-sm
  border-top-left-radius: $radius-sm

.rounded-borders-bottom
  border-bottom-right-radius: $radius-sm
  border-bottom-left-radius: $radius-sm

.rounded-borders-left
  border-top-left-radius: $radius-sm
  border-bottom-left-radius: $radius-sm

.text-overflow-ellipsis
  white-space: nowrap
  overflow: hidden
  text-overflow: ellipsis

.line-clamp
  height: unset
  overflow: hidden
  display: -webkit-box
  -webkit-box-orient: vertical

.line-clamp-3
  @extend .line-clamp
  -webkit-line-clamp: 3

.line-clamp-2
  @extend .line-clamp
  -webkit-line-clamp: 2

.line-clamp-1
  @extend .line-clamp
  -webkit-line-clamp: 1

.prevent-select
  user-select: none !important

.word-break-all
  word-break: break-all

.text-pre-wrap
  white-space: pre-wrap

.animate
  transition: all 1s

.transition-default
  transition: .3s ease

.row-grid
  display: grid

.line-height-default
  line-height: 1

.strip-item
  min-height: 0px

# --- Application Configuration ---

# General Settings
ENV=development
CORS_OVERRIDE_ALLOWED_ORIGINS=http://localhost:7000,http://localhost:7002,http://localhost:8000
# PORT=8000
# SECRET_ENCRYPTION_KEY=my-secret-key-tsmh5r


# Database Settings (PostgreSQL)
# Used by the application to connect to the DB
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=magnet_dev
DB_USER=postgres
DB_PASSWORD=password
DATABASE_ECHO=True

# Vector Database Settings
# VECTOR_DB_TYPE=PGVECTOR
# PGVECTOR_HOST=localhost
# PGVECTOR_PORT=5432
# PGVECTOR_DATABASE=magnet_dev
# PGVECTOR_USER=postgres
# PGVECTOR_PASSWORD=password

# Authentication Settings
AUTH_ENABLED=False
# MICROSOFT_ENTRA_ID_TENANT_ID=
# MICROSOFT_ENTRA_ID_CLIENT_ID=
# MICROSOFT_ENTRA_ID_CLIENT_SECRET=
# WEB_AUTH_PROVIDER_TITLE=Microsoft
# WEB_AUTH_POPUP_WIDTH=600
# WEB_AUTH_POPUP_HEIGHT=400

# MCP Server (expose Magnet APIs to Claude / MCP Inspector / Postman / etc.)
# See docs/MCP_CONNECTOR_SETUP.md for setup walkthrough.
# MCP_ENABLED=False
# MCP_ISSUER_URL=https://magnet.example.com
# MCP_AUDIENCE=https://magnet.example.com/mcp
# MCP_AUTH_CODE_TTL_SECONDS=300
# MCP_PENDING_STATE_TTL_SECONDS=600
# MCP_LOGIN_URL=/admin/login

# Knowledge Sources
# KNOWLEDGE_SOURCE_HUBSPOT=
# FLUID_TOPICS_API_KEY=
# SHAREPOINT_TENANT_ID=
# SHAREPOINT_CLIENT_ID=
# SHAREPOINT_CLIENT_SECRET=

# Observability & Logging
# LOG_LEVEL=10
# OBSERVABILITY_ENABLED=True
# LOKI_URL=

# --- Runtime Flags ---
# RUN_MIGRATIONS=false
# RUN_FIXTURES=false
# RESET_DB=false
# BUILD_DOCS=true
# WEB_BASE_PATH=/

# --- TaskIQ (single-container in-process layout) ---
# Default true: worker + scheduler run as asyncio tasks inside the API process.
# Set both to false locally if you prefer separate `taskiq worker` / `taskiq scheduler`
# CLI processes (e.g. `npm run dev`).
# TASKIQ_INPROCESS_WORKER_ENABLED=true
# TASKIQ_INPROCESS_SCHEDULER_ENABLED=true
# TASKIQ_WORKER_CONCURRENCY=2
# TASKIQ_SCHEDULER_UPDATE_INTERVAL=10
